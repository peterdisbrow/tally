{
  "expo": {
    "name": "Tally Connect",
    "slug": "tally-connect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "tallyconnect",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tallyconnect.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tallyconnect.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/0c3a1fe4-2836-4e46-8b14-19fe5590a39d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "0c3a1fe4-2836-4e46-8b14-19fe5590a39d"
      },
      "router": {}
    },
    "owner": "peterdisbrow"
  }
}
