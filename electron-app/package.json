{
  "name": "tally-connect",
  "version": "1.1.57",
  "description": "Tally — Remote monitoring for ATEM School customers",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mac": "bash ../scripts/bump-version.sh patch && electron-builder --mac",
    "build:mac:nobump": "electron-builder --mac",
    "build:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:mac:signed": "npm run release:check && electron-builder --mac --arm64 --x64",
    "build:mac:dist": "mkdir -p \"$HOME/Desktop/Tally\" && electron-builder --mac && cp -f dist/Tally-*.dmg \"$HOME/Desktop/Tally/\"",
    "build:win": "electron-builder --win",
    "build:win:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:win:signed": "npm run release:check && electron-builder --win --x64",
    "build:all": "npm run build:mac:unsigned",
    "release:check": "node scripts/release-readiness-check.js",
    "release:check:mac": "node scripts/release-readiness-check.js --profile mac-unsigned",
    "release:mac": "npm run release:check:mac && npm run build:mac:unsigned",
    "test": "node --test test/*.test.js && npx playwright test",
    "test:unit": "node --test test/*.test.js",
    "test:coverage": "c8 --check-coverage --reporter=text --reporter=html --reporter=lcov node --test test/*.test.js",
    "test:e2e": "npx playwright test"
  },
  "build": {
    "appId": "com.tallyconnect.tally",
    "productName": "Tally",
    "copyright": "Copyright © 2026 Tally Connect",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!src/main-mock-lab.js",
      "!src/mock-lab.html",
      "!src/mockLabManager.js",
      "!src/preload-mock-lab.js",
      "!dist{,/**/*}",
      "!dist-mock-lab{,/**/*}",
      "!.git{,/**/*}",
      "!**/.DS_Store"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "notarize": true
    },
    "dmg": {
      "artifactName": "${productName}-${arch}.dmg",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "peterdisbrow",
      "repo": "tally"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "afterPack": "./scripts/afterPack.js",
    "extraResources": [
      {
        "from": "../church-client",
        "to": "church-client",
        "filter": [
          "**/*",
          "!src/fakeAtem.js",
          "!src/fakeAtemApi.js",
          "!src/fakeObs.js",
          "!src/fakeMixer.js",
          "!src/fakeProPresenter.js",
          "!.git",
          "!.git/**"
        ]
      },
      {
        "from": "../problem-finder-lab",
        "to": "problem-finder-lab",
        "filter": [
          "**/*",
          "!.git",
          "!.git/**",
          "!ui/**",
          "!mockups/**",
          "!output/**",
          "!docs/**",
          "!data/**",
          "!node_modules/**",
          "!.DS_Store"
        ]
      }
    ]
  },
  "dependencies": {
    "atem-connection": "^3.9.0",
    "commander": "^12.0.0",
    "electron-updater": "^6.1.0",
    "obs-websocket-js": "^5.0.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2"
  },
  "c8": {
    "include": [
      "src/**"
    ],
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "check-coverage": true,
    "statements": 48,
    "branches": 68,
    "functions": 40,
    "lines": 48
  }
}
