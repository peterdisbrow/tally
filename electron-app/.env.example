# Tally Connect — Environment Variables
# Copy this file to .env and fill in the values.

# ─── Relay Server ────────────────────────────────────────────────────────────
# WebSocket URL for the Tally relay server.
# Default: wss://api.tallyconnect.app
# TALLY_DEFAULT_RELAY_URL=wss://api.tallyconnect.app

# ─── YouTube OAuth ───────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Create a "Desktop app" client. Enable the YouTube Data API v3.
# The client SECRET stays on the relay server — only the client ID is needed here.
# YOUTUBE_CLIENT_ID=

# ─── Facebook OAuth ──────────────────────────────────────────────────────────
# Meta for Developers → Your App → Settings → Basic → App ID
# Required permissions: pages_show_list, pages_manage_posts, publish_video
# The app secret stays on the relay server — only the app ID is needed here.
# FACEBOOK_APP_ID=
