{
  "name": "tally-relay",
  "version": "1.1.39",
  "description": "Relay server bridging ATEM School OpenClaw skill to church client apps",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check:routes": "node scripts/check-duplicate-routes.js server.js src/churchPortal.js src/resellerPortal.js",
    "backup:db": "node scripts/backup-db.js",
    "restore:db": "node scripts/restore-db.js",
    "lint": "eslint . --ext .js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "node ../test/integration.js",
    "test:all": "npm test && npm run test:integration"
  },
  "dependencies": {
    "@sentry/node": "^10.43.0",
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^14.1.4",
    "node-media-server": "^4.2.4",
    "stripe": "^20.3.1",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.2",
    "nodemon": "^3.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}
