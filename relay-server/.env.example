# Church AV Relay Server Environment Variables
# Copy to .env and fill in your values

# Required: Secret key for admin API access (generate a strong random string)
ADMIN_API_KEY=change-me-to-a-strong-random-string

# Required: Secret for signing church JWT tokens (generate a strong random string)
JWT_SECRET=change-me-to-a-different-strong-random-string

# Optional: Server port (Railway sets this automatically)
# PORT=3000

# Optional: database runtime.
# Use sqlite for local file-backed development or postgres for Neon/Postgres deployments.
# DATABASE_DRIVER=sqlite

# Optional: SQLite database path
# DATABASE_PATH=./data/churches.db

# Postgres / Neon connection string (required when DATABASE_DRIVER=postgres).
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Optional: Sentry error tracking DSN (https://sentry.io)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional: Structured JSON logging (set to "json" for Railway log parsing)
# LOG_FORMAT=json

# Optional: relay version override (default reads package.json version)
# RELAY_VERSION=1.1.0

# Optional: credential-login token TTL (default: 30d)
# TALLY_CHURCH_APP_TOKEN_TTL=30d

# Optional: require active/trialing billing before church clients can connect
# Defaults to true in production, false in local/dev.
# TALLY_REQUIRE_ACTIVE_BILLING=true

# Optional: ticket creation triage freshness window (hours)
# SUPPORT_TRIAGE_WINDOW_HOURS=24

# Optional: Redis socket backend (recommended before multi-instance deploys)
# Enables distributed rate limiting plus runtime coordination/presence.
# REDIS_URL=redis://default:password@host:6379
# Alternate host/port form:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=change-me
# REDIS_TLS=false
#
# Optional: Upstash Redis socket URL (if provided, socket Redis is preferred over REST)
# UPSTASH_REDIS_URL=rediss://default:password@host.upstash.io:6379
#
# Optional: runtime coordination tuning for cross-instance presence/pubsub
# TALLY_INSTANCE_ID=railway-replica-1
# RUNTIME_COORDINATION_PREFIX=tally:runtime
# RUNTIME_COORDINATION_CHANNEL=tally:runtime:events
# RUNTIME_PRESENCE_TTL_MS=45000
#
# Optional: latest-preview cache retention for pull-based preview delivery
# PREVIEW_FRAME_CACHE_TTL_MS=30000
#
# Optional: persistent rate limiting via REST (works without a raw Redis socket,
# but only covers rate limiting — not runtime presence/pubsub).
# Supports Upstash Redis REST or Vercel KV REST envs.
# UPSTASH_REDIS_REST_URL=https://<your-upstash-endpoint>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>
# KV_REST_API_URL=https://<your-vercel-kv-endpoint>.upstash.io
# KV_REST_API_TOKEN=<your-vercel-kv-rest-token>
# Optional key prefix override
# RATE_LIMIT_KEY_PREFIX=tally:rl

# ─── Telegram Bot (TD Interface) ───────────────────
# Create a bot via @BotFather on Telegram, paste the token here
TALLY_BOT_TOKEN=

# Telegram webhook endpoint (public URL)
# Public URL of your relay server + /api/telegram-webhook
# e.g., https://tally-relay.up.railway.app/api/telegram-webhook
TALLY_BOT_WEBHOOK_URL=

# Optional: secret token to verify Telegram webhooks (x-telegram-bot-api-secret-token)
TALLY_BOT_WEBHOOK_SECRET=

# Andrew's personal Telegram chat ID (admin access — can control any church)
ANDREW_TELEGRAM_CHAT_ID=
ALLOWED_ORIGINS=https://tallyconnect.app,https://your-dashboard-domain.com

# ─── Stripe Billing ───────────────────────────────────────────────────────────
# Get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard (Products → Prices)
# Monthly prices (required for recurring plans)
STRIPE_PRICE_CONNECT=price_...
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MANAGED=price_...

# Annual prices (optional, required only if offering annual billing)
STRIPE_PRICE_CONNECT_ANNUAL=price_...
STRIPE_PRICE_PLUS_ANNUAL=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_MANAGED_ANNUAL=price_...

# One-time event price (required if offering Event mode checkout)
STRIPE_PRICE_EVENT=price_...

# Your web app public URL (for redirects/emails), e.g. https://tallyconnect.app
APP_URL=https://tallyconnect.app

# Optional explicit URL for Admin API proxy health checks.
# If omitted, status checks will try APP_URL first, then api.<APP_URL host>.
# ADMIN_PROXY_URL=https://api.tallyconnect.app

# ─── Status & Backup Ops ──────────────────────────────────────────────────────
# Optional: run DB snapshot job every N minutes (0 = disabled)
# DB_BACKUP_INTERVAL_MINUTES=30

# Optional: backup output directory (defaults to <DATABASE_PATH dir>/backups)
# BACKUP_DIR=/data/backups

# Optional: keep last N snapshots on disk
# BACKUP_RETAIN_COUNT=96

# Optional: encryption key for backups (64-char hex, base64, or passphrase)
# BACKUP_ENCRYPTION_KEY=
