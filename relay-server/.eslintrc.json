{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-constant-condition": "warn",
    "no-dupe-keys": "error",
    "eqeqeq": ["warn", "always"],
    "no-throw-literal": "warn"
  },
  "ignorePatterns": ["node_modules/", "data/"]
}
