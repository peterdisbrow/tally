# Copy this file to cloudflare.env and fill in the values.

# Required: create an API token in Cloudflare with Zone:Read and DNS:Edit.
CLOUDFLARE_API_TOKEN=

# Optional but recommended if your token can see multiple accounts.
CLOUDFLARE_ACCOUNT_ID=

# Use one of these:
# 1. Set CLOUDFLARE_ZONE_ID directly, or
# 2. Set CLOUDFLARE_ZONE_NAME and let the script resolve the zone.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=tallyconnect.app
